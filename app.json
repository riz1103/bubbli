{
  "expo": {
    "name": "Bubbli",
    "slug": "Bubbli",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/bubbli-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bubbli uses the microphone for speaking and reading practice.",
        "NSSpeechRecognitionUsageDescription": "Bubbli uses speech recognition to respond to your child's reading."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EEF6F4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.Bubbli"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-av",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Bubbli uses the microphone for speaking and reading practice.",
          "speechRecognitionPermission": "Bubbli uses speech recognition to respond to your child's reading."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0375c23c-a33e-4512-8a9d-bf2faedc0716"
      }
    },
    "owner": "joseriz"
  }
}
